const fs   = require("fs");
const path = require("path");
 
const SNAPSHOT = path.join(__dirname, "db.snapshot.json");
const TARGET   = path.join(__dirname, "db.json");
const INTERVAL = 24 * 60 * 60 * 1000; // 24 hours in milliseconds
 
// ── Snapshot check ────────────────────────────────────────────────────────────
if (!fs.existsSync(SNAPSHOT)) {
  console.error("❌  db.snapshot.json not found!");
  console.error("    Please copy your original db.json as db.snapshot.json:");
  console.error("    cp db.json db.snapshot.json");
  process.exit(1);
}
 
// ── Reset function ────────────────────────────────────────────────────────────
function resetDb() {
  try {
    const snapshot = fs.readFileSync(SNAPSHOT, "utf8");
    fs.writeFileSync(TARGET, snapshot, "utf8");
    const now = new Date().toLocaleString("en-IN", { timeZone: "Asia/Kolkata" });
    console.log(`✅  [${now}] db.json has been reset to original snapshot.`);
  } catch (err) {
    console.error("❌  Reset failed:", err.message);
  }
}
 
// ── Schedule ──────────────────────────────────────────────────────────────────
console.log("🔄  DB Auto-Reset service started.");
console.log(`    Reset will occur every 24 hours.`);
console.log(`    Next reset: ${new Date(Date.now() + INTERVAL).toLocaleString("en-IN", { timeZone: "Asia/Kolkata" })}`);
 
// First reset after 24h, then repeat
setInterval(() => {
  resetDb();
  console.log(`    Next reset: ${new Date(Date.now() + INTERVAL).toLocaleString("en-IN", { timeZone: "Asia/Kolkata" })}`);
}, INTERVAL);